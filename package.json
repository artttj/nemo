{
  "name": "nemo",
  "version": "0.0.1",
  "description": "A local-first password manager with passkey authentication",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "4.4.1",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.21",
    "wxt": "^0.19.11"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.10",
      "brace-expansion": ">=1.1.13",
      "esbuild": ">=0.25.0",
      "vite": ">=5.4.21"
    }
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab",
      "clipboardWrite",
      "clipboardRead"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}